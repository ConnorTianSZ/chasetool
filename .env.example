# ── LLM ──────────────────────────────────────────────────────────
# 通用 API key（优先级最高）
API_KEY=
# 自定义端点（OpenAI 兼容格式）
# DeepSeek: https://api.deepseek.com
API_BASE=https://api.deepseek.com
# 模型名
# DeepSeek V4 Flash: deepseek-v4-flash
LLM_MODEL=deepseek-v4-flash
# 供应商：anthropic / openai / custom
# DeepSeek 用 custom
LLM_PROVIDER=custom
# 保留向后兼容（使用 DeepSeek 时留空）
ANTHROPIC_API_KEY=

# ── 代理（企业网络必填，否则无法访问外网 API）────────────────────
# Bosch APAC 代理（经生产环境验证）
HTTPS_PROXY=http://rb-proxy-apac.bosch.com:8080
HTTP_PROXY=http://rb-proxy-apac.bosch.com:8080
# 非企业网络环境留空即可
# HTTPS_PROXY=
# HTTP_PROXY=

# ── Outlook ───────────────────────────────────────────────────────
OUTLOOK_PROFILE=
INBOX_FOLDER=Inbox
INBOUND_PULL_DAYS=14

# ── 路径 ──────────────────────────────────────────────────────────
DATA_DIR=./data
EXCEL_DEFAULT_DIR=

# ── 行为 ──────────────────────────────────────────────────────────
CHASE_DEFAULT_MODE=draft
SEND_INTERVAL_SECONDS=2
TIMEZONE=Asia/Shanghai

# ── 服务 ──────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
