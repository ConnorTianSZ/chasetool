# ══════════════════════════════════════════════════════════════════
# LLM 配置 — 两种模式，二选一
# ══════════════════════════════════════════════════════════════════

# ── 模式 1：本地代理模式（推荐用于公司环境）─────────────────────
# 先启动 proxy_server.py，再启动 ChaseBase。
# proxy_server.py 负责走企业代理 → DeepSeek，ChaseBase 直连本机。
#
# API_KEY=local-proxy          # 任意字符串，代理不验证
# API_BASE=http://127.0.0.1:11434/v1
# LLM_MODEL=deepseek-chat      # 代理会用自己的 LLM_MODEL 覆盖
# LLM_PROVIDER=openai          # 走标准 OpenAI SDK，无需设系统代理
# ANTHROPIC_API_KEY=
# HTTPS_PROXY=                 # ChaseBase 侧不需要设代理
# HTTP_PROXY=

# ── 模式 2：直连模式（家庭/开发环境或有稳定代理时）─────────────
# 通用 API key（优先级最高）
API_KEY=
# 自定义端点（OpenAI 兼容格式）
# DeepSeek: https://api.deepseek.com
API_BASE=https://api.deepseek.com
# 模型名
# DeepSeek: deepseek-chat / deepseek-v4-flash
LLM_MODEL=deepseek-chat
# 供应商：anthropic / openai / custom
# DeepSeek 用 custom（走 urllib 代理路径）
LLM_PROVIDER=custom
# 保留向后兼容（使用 DeepSeek 时留空）
ANTHROPIC_API_KEY=

# ── 代理（直连模式下企业网络必填）────────────────────────────────
# Bosch APAC 代理（经生产环境验证）
HTTPS_PROXY=http://rb-proxy-apac.bosch.com:8080
HTTP_PROXY=http://rb-proxy-apac.bosch.com:8080
# 非企业网络环境留空即可
# HTTPS_PROXY=
# HTTP_PROXY=

# ── 本地代理服务配置（proxy_server.py 读取）─────────────────────
# 仅当运行 proxy_server.py 时有效
# proxy_server.py 会从此 .env 读取真实的 API_KEY 和 HTTPS_PROXY
LOCAL_PROXY_HOST=127.0.0.1
LOCAL_PROXY_PORT=11434

# ── Outlook ───────────────────────────────────────────────────────
OUTLOOK_PROFILE=
INBOX_FOLDER=Inbox
INBOUND_PULL_DAYS=14

# ── 路径 ──────────────────────────────────────────────────────────
DATA_DIR=./data
EXCEL_DEFAULT_DIR=

# ── 行为 ──────────────────────────────────────────────────────────
CHASE_DEFAULT_MODE=draft
SEND_INTERVAL_SECONDS=2
TIMEZONE=Asia/Shanghai

# ── 服务 ──────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
